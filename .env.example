# ─────────────────────────────────────────────────────────────────────────────
# table-bench-mark environment. Copy to `.env` and adjust as needed.
# ─────────────────────────────────────────────────────────────────────────────
COMPOSE_PROJECT_NAME=table-bench-mark

# ---- Component image versions (pinned for reproducibility) -------------------
# StarRocks (query engine) versions to benchmark, in order. scripts/run.sh swaps the
# container per version and merges results. STARROCKS_VERSION is the default/up version.
SR_VERSIONS=4.1.1
STARROCKS_VERSION=4.1.1
POLARIS_VERSION=1.5.0
SPARK_VERSION=3.5.3
POSTGRES_VERSION=16
MINIO_VERSION=RELEASE.2025-04-08T15-41-24Z

# Connector / library versions baked into the custom Flink image.
# (Flink minor version <-> connector version compatibility is strict; see CLAUDE.md.)
SCALA_VERSION=2.12
ICEBERG_VERSION=1.10.2
PAIMON_VERSION=1.2.0
FLINK_STARROCKS_CONNECTOR_VERSION=1.2.14_flink-1.20
HADOOP_VERSION=3.3.6

# ---- MinIO (S3-compatible object store / warehouse) --------------------------
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=password123
MINIO_ENDPOINT=http://minio:9000
MINIO_REGION=us-east-1
WAREHOUSE_BUCKET=warehouse

# ---- Postgres (Polaris metadata persistence) ---------------------------------
POSTGRES_USER=polaris
POSTGRES_PASSWORD=polaris
POSTGRES_DB=polaris

# ---- Polaris (Iceberg REST catalog) ------------------------------------------
POLARIS_CATALOG_NAME=polaris_catalog
# Root client credentials issued by Polaris bootstrap (client_id:client_secret).
# Filled in by infra/polaris/bootstrap.sh at first run; override here to pin.
POLARIS_CLIENT_ID=root
POLARIS_CLIENT_SECRET=s3cr3t
POLARIS_PRINCIPAL_ROLE=PRINCIPAL_ROLE:ALL

# ---- StarRocks ---------------------------------------------------------------
SR_FE_HOST=starrocks
SR_QUERY_PORT=9030
SR_HTTP_PORT=8030
SR_USER=root
SR_PASSWORD=

# ---- Flink -------------------------------------------------------------------
FLINK_JOBMANAGER_HOST=flink-jobmanager
FLINK_SQL_GATEWAY_PORT=8083
FLINK_REST_PORT=8081

# ---- Resource caps (measurement stability) -----------------------------------
# Per-container memory/CPU ceilings. Purpose: stop any one service from ballooning and
# pushing the Docker VM into swap — swap/memory-pressure is the prime cause of the one-off
# 3-6x latency spikes seen in single-sample steps (load/compact/freshness).
#
# SIZING RULE: sum of all *_MEM must be <= the Docker VM's memory allocation
#   (Docker Desktop > Settings > Resources, or settings.json `memoryMiB`).
#   Defaults below target a ~24g / 8-CPU VM: mem sum ≈ 22.5g (SPARK_MEM raised to 11g for the
#   heaviest combo). Caps are ceilings, not reservations: StarRocks (read_engines=spark here)
#   stays idle during Spark-heavy writes, so real concurrent use is far below the sum.
#   If your VM is smaller, lower SPARK_MEM / STARROCKS_MEM first.
# NOTE: cpus values are upper bounds; Spark (writer) and StarRocks (reader) are never both
#   fully loaded during a measured step, so their caps may overlap the VM core count.
SPARK_MEM=11g
SPARK_CPUS=6
STARROCKS_MEM=6g
STARROCKS_CPUS=6
MINIO_MEM=2g
MINIO_CPUS=2
POLARIS_MEM=1500m
POLARIS_CPUS=2
POSTGRES_MEM=1g
POSTGRES_CPUS=1
RUNNER_MEM=1g
RUNNER_CPUS=2

# ---- Benchmark parameters (override config/benchmark.yaml at runtime) ---------
BENCH_SEED=42
BENCH_ROUNDS=50
BENCH_ROWS_PER_ROUND=100000
BENCH_INITIAL_ROWS=100000
BENCH_UPDATE_RATIO=0.20
# Quiescence: idle settle (seconds) inserted just BEFORE each measured step's timer (outside
# it) so the prior step's residual IO/commit/GC drains into this gap instead of the next
# measurement window. Applied uniformly to all candidates (fairness preserved). 0 = old behavior.
BENCH_SETTLE_S=1.0
