# Benchmark artifacts
/staging/*
!/staging/.gitkeep
# results/ is committed so the measured data + reports + graphs are shareable.
# Only transient/scratch runs are ignored (smoke, snapshot tests, agg scratch).
/results/smoke-*
/results/_*
/results/*-agg2
/results/*-merge-test

# Python
__pycache__/
*.py[cod]
.venv/
venv/
*.egg-info/
.pytest_cache/

# Env / secrets
.env

# Docker / data volumes
/.data/

# OS / editor
.DS_Store
.idea/
.vscode/

# Local Claude Code settings
.claude/settings.local.json
